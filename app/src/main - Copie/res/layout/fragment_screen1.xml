<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".Screen1Fragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <TextView
            android:id="@+id/labelScreen1Fragment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Detail incident"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/detailCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelScreen1Fragment">

            <ImageView
                android:id="@+id/picture"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="Incident"
                android:src="@drawable/ic_alert" />

            <TextView
                android:id="@+id/detailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Aucun incident selectionne"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/MainFragment_content"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/detailMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Priorite - Statut - Type"
                android:textColor="@color/text_subtle"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailProtocol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_badge_warning"
                android:lineSpacingExtra="4dp"
                android:padding="12dp"
                android:text="Protocole de securite disponible apres selection."
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/camera_fragment_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <Button
            android:id="@+id/button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_outline"
            android:text="Retour"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/detailCard" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
