<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_nav_bar"
    android:paddingStart="6dp"
    android:paddingTop="6dp"
    android:paddingEnd="6dp"
    android:paddingBottom="6dp"
    tools:context=".MenuFragment">

    <TextView
        android:id="@+id/txtFragmentMenu"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:gravity="center"
        android:text="SignalRoute"
        android:textColor="@color/text_subtle"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/itemsMenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtFragmentMenu">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:tag="0"
            android:contentDescription="@string/nav_map"
            android:src="@drawable/ic_map"
            app:shapeAppearanceOverlay="@style/MenuImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:tag="1"
            android:contentDescription="@string/nav_list"
            android:src="@drawable/ic_list"
            app:shapeAppearanceOverlay="@style/MenuImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:tag="2"
            android:contentDescription="@string/nav_report"
            android:src="@drawable/ic_alert"
            app:shapeAppearanceOverlay="@style/MenuImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:tag="3"
            android:contentDescription="@string/nav_voice"
            android:src="@drawable/ic_mic"
            app:shapeAppearanceOverlay="@style/MenuImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:tag="4"
            android:contentDescription="@string/nav_history"
            android:src="@drawable/ic_notifications"
            app:shapeAppearanceOverlay="@style/MenuImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:tag="5"
            android:contentDescription="@string/nav_settings"
            android:src="@drawable/ic_settings"
            app:shapeAppearanceOverlay="@style/MenuImage" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
